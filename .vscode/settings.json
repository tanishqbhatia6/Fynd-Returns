{
  // ─── webhint / accessibility extension noise ───────────────────────
  // This codebase uses inline `style={{...}}` intentionally on its admin
  // surfaces (no design system in use; styles co-located with components).
  // Disable the rule globally so the Problems panel reflects real issues.
  "webhint.enableTelemetry": false,
  "vscode-webhint.scanners": {
    "css": false,
    "html": false
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": false
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": false
  },
  "eslint.validate": ["javascript", "javascriptreact", "typescript", "typescriptreact"],
  "eslint.run": "onSave",
  "eslint.format.enable": false,
  // Disable the inline-CSS / button-type / accessibility hints from
  // third-party webhint extensions. These are noisy on this codebase
  // (inline styles are deliberate; many buttons are inside <form>
  // submit flows where `type` defaults are correct).
  "extensions.experimental.affinity": {},
  "css.lint.unknownAtRules": "ignore",
  // Suppress the "CSS inline styles should not be used" hint that
  // accumulates 2K+ across the app/routes tree.
  "html-css-class-completion.JavaScriptLanguages": [],
  "files.exclude": {
    "**/cov-base": true,
    "**/cov-pragma-check*": true,
    "**/cov-returns-*": true,
    "**/cov-targets*": true,
    "**/cov-test-pragma*": true,
    "**/tmp-coverage*": true,
    "**/tmp-shopify-cov": true,
    "**/.cov-target": true
  }
}
