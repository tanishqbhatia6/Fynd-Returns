// Return Pro Max - Fynd ↔ Shopify Returns Manager
// PostgreSQL for enterprise-grade multi-tenant data

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id                 String    @id
  shop               String
  state              String
  isOnline           Boolean   @default(false)
  scope              String?
  expires            DateTime?
  accessToken        String
  userId             BigInt?
  firstName          String?
  lastName           String?
  email              String?
  accountOwner       Boolean   @default(false)
  locale             String?
  collaborator       Boolean?  @default(false)
  emailVerified      Boolean?  @default(false)
  refreshToken       String?
  refreshTokenExpires DateTime?
}

model Shop {
  id          String   @id @default(cuid())
  shopDomain  String   @unique
  installedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  settings    ShopSettings?
  returnCases ReturnCase[]
}

model ShopSettings {
  id                         String   @id @default(cuid())
  shopId                     String   @unique
  shop                       Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  fyndApiType                String?  // "platform" | "storefront"
  fyndEnvironment            String?  // "uat" | "prod"
  fyndCustomBaseUrl          String?  // optional override
  appMode                    String?  // "dev" | "prod"
  fyndCompanyId              String?
  fyndApplicationId          String?
  fyndCredentials            String?
  policyJson                 String?
  statusMappingJson          String?
  notificationToggles          String?
  portalThemeJson            String?
  portalConfigJson           String?
  returnWindowDays           Int      @default(30)
  returnReasonsJson          String?
  returnReasonsByCategoryJson String?
  returnPolicyText           String?
  autoApproveEnabled         Boolean  @default(false)
  autoRefundEnabled          Boolean  @default(false)  // Auto-trigger Shopify refund on credit_note_generated
  refundLocationMode         String   @default("auto") // "auto" = use order fulfillment location, "manual" = admin picks location in modal
  refundLocationId           String?  // Shopify location GID for auto mode fallback (when fulfillment location unavailable)
  refundPaymentMethod        String   @default("original") // "original" | "store_credit" | "both"
  refundStoreCreditPct       Int?     @default(100) // % of refund as store credit when method is "both"
  returnOffersJson          String?
  minimumReturnPrice         Decimal? @db.Decimal(12, 2)
  restrictedRegionsJson      String?
  noReturnPeriodEnabled      Boolean  @default(false)
  noReturnPeriodStart        DateTime?
  noReturnPeriodEnd          DateTime?
  restrictedProductTagsJson  String?
  photoRequired              Boolean  @default(false)
  returnFeeAmount            Decimal? @db.Decimal(12, 2)
  returnFeeCurrency          String?
  refundMethodPrepaidJson    String?
  refundMethodCODJson        String?
  notificationNewReturn      Boolean  @default(true)
  notificationApproved       Boolean  @default(true)
  notificationRejected       Boolean  @default(true)
  notificationRefunded       Boolean  @default(true)
  smtpHost                   String?
  smtpPort                   Int?     @default(587)
  smtpUser                   String?
  smtpPass                   String?
  smtpFromEmail              String?
  smtpFromName               String?
  smtpSecure                 Boolean  @default(false)
  adminNotifyEmail           String?
  adminSoundEnabled          Boolean  @default(true)
  readAllOrdersEnabled       Boolean  @default(false)

  // Store credit bonus incentive
  bonusCreditEnabled         Boolean  @default(false)
  bonusCreditPct             Int      @default(10) // Extra % bonus when customer chooses store credit/exchange

  // Green returns (keep item + refund)
  greenReturnsEnabled        Boolean  @default(false)
  greenReturnsThreshold      Decimal? @db.Decimal(12, 2) // Items below this value: customer keeps item
  greenReturnsProductTags    String?  // JSON array of product tags eligible for green returns

  // Advanced auto-approve rules
  autoApproveRulesJson       String?  @db.Text // JSON array of rule objects

  // Customer blocklist
  blocklistEnabled           Boolean  @default(false)

  // Multi-language portal
  portalLanguage             String   @default("en")
  portalLabelsJson           String?  @db.Text // JSON { key: translatedLabel } overrides

  // Return shipping label
  defaultReturnInstructions  String?  @db.Text // Default instructions shown to customer after approval

  // Customizable email templates
  emailTemplatesJson         String?  @db.Text // JSON { eventType: { subject, bodyHtml } }

  // Product-level return policies
  productPoliciesJson        String?  @db.Text // JSON array: [{ match: {tags?, collections?, productTypes?}, windowDays, policyText? }]

  // Discount code refund
  discountCodeRefundEnabled  Boolean  @default(false)
  discountCodePrefix         String?  @default("RETURN")
  discountCodeExpiryDays     Int      @default(90)

  // Return offers / incentives
  returnOffersEnabled        Boolean  @default(false) // Offer discounts to keep item instead of returning

  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  blocklist                  BlocklistEntry[]
}

model ReturnCase {
  id                String   @id @default(cuid())
  returnRequestNo   String?  // User-friendly ID e.g. RPM-A1B2C3D4 for display and lookup
  shopId            String
  shop              Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  shopifyOrderId    String
  shopifyOrderName  String
  shopifyReturnId   String?
  fyndReturnId      String?
  fyndReturnNo      String?
  fyndOrderId       String?   // Fynd affiliate_order_id for API (from order customAttributes); NOT Shopify order name
  fyndShipmentId    String?   // main shipment ID from Fynd
  fyndPayloadJson   String?   // full Fynd order/shipment payload for invoice, AWB, DP, etc.
  forwardAwb        String?
  returnAwb         String?
  customerEmailNorm String?
  customerPhoneNorm String?
  status            String
  refundStatus      String?
  refundJson        String?   @db.Text  // JSON: { refundId, amount, currency, createdAt, method }
  adminNotes        String?
  notesForCustomer  String?   // published notes visible to customer in portal
  customerNotes     String?
  customerMediaJson String?   @db.Text  // JSON array of { name, mimeType, dataUrl } uploaded by customer
  rejectionReason   String?
  resolutionType    String    @default("refund") // "refund" | "exchange" | "store_credit" | "replacement"
  exchangeOrderId   String?   // Shopify order ID created for exchange
  exchangeOrderName String?   // Shopify order name for exchange
  exchangeItemsJson String?   @db.Text // JSON array of exchanged item details
  returnLabelUrl    String?   // URL to return shipping label (uploaded or generated)
  returnLabelJson   String?   @db.Text // JSON: { carrier, trackingNumber, labelUrl, qrCodeUrl }
  isGreenReturn     Boolean   @default(false) // Customer keeps item
  bonusCreditAmount String?   // Extra bonus credit applied
  discountCode      String?   // Generated discount code for refund
  discountCodeValue String?   // Amount of the discount code
  orderProcessedAt  DateTime? // Original order processed date (for deadline calculation)
  fyndSyncStatus    String?   // "pending" | "synced" | "failed" | "retry_scheduled"
  fyndSyncRetries   Int      @default(0)
  fyndSyncError     String?  @db.Text
  fyndSyncNextRetry DateTime?
  lastFyndStatusCheck DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  items  ReturnItem[]
  events ReturnEvent[]

  @@index([shopId, shopifyOrderName])
  @@index([shopId, forwardAwb])
  @@index([shopId, returnAwb])
  @@index([shopId, fyndReturnId])
  @@index([shopId, fyndShipmentId])
  @@index([shopId, fyndOrderId])
  @@index([shopId, returnRequestNo])
  @@index([shopId, customerEmailNorm])
  @@index([shopId, customerPhoneNorm])
  @@index([fyndSyncStatus, fyndSyncNextRetry])
}

model ReturnItem {
  id               String    @id @default(cuid())
  returnCaseId     String
  returnCase       ReturnCase @relation(fields: [returnCaseId], references: [id], onDelete: Cascade)
  shopifyLineItemId String
  title            String?
  variantTitle     String?
  sku              String?
  price            String?
  imageUrl         String?
  qty              Int       @default(1)
  reasonCode       String?
  notes            String?
  fyndShipmentId   String?
  fyndBagId        String?
  createdAt        DateTime  @default(now())

  @@index([returnCaseId])
}

model ReturnEvent {
  id          String   @id @default(cuid())
  returnCaseId String
  returnCase  ReturnCase @relation(fields: [returnCaseId], references: [id], onDelete: Cascade)
  source      String
  eventType   String
  payloadJson String?
  happenedAt  DateTime @default(now())

  @@index([returnCaseId])
}

model FyndWebhookLog {
  id          String   @id @default(cuid())
  shipmentId  String?
  orderId     String?
  refundStatus String?
  action      String?  // ignored | refund_in_progress | refund_completed
  returnCaseId String?
  rawPayload  String?  @db.Text
  error       String?  @db.Text
  createdAt   DateTime @default(now())

  @@index([shipmentId])
  @@index([orderId])
  @@index([returnCaseId])
  @@index([createdAt])
}

model FyndOrderMapping {
  id                String   @id @default(cuid())
  shopId            String
  shopifyOrderName  String
  shopifyOrderId    String?
  fyndOrderId       String?
  fyndShipmentId    String?
  searchStrategy    String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([shopId, shopifyOrderName])
  @@index([shopId, fyndOrderId])
  @@index([shopId, fyndShipmentId])
}

model LookupSession {
  id               String   @id @default(cuid())
  shopId           String
  lookupType       String
  lookupValueHash  String
  lookupValueNorm  String?
  matchedReturnIds String?
  otpTarget        String?
  otpSentAt        DateTime?
  verifiedAt       DateTime?
  expiresAt        DateTime
  attemptsCount    Int      @default(0)
  portalToken      String?
  createdAt        DateTime @default(now())

  @@index([shopId, lookupValueHash])
}

model BlocklistEntry {
  id             String   @id @default(cuid())
  settingsId     String
  settings       ShopSettings @relation(fields: [settingsId], references: [id], onDelete: Cascade)
  type           String   // "email" | "phone" | "order_name" | "ip"
  value          String   // normalized value
  reason         String?
  blockedBy      String?  // admin who added
  createdAt      DateTime @default(now())

  @@unique([settingsId, type, value])
  @@index([settingsId, type])
}
