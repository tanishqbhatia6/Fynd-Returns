{
  "name": "returnpromax",
  "private": true,
  "scripts": {
    "build": "react-router build",
    "dev": "npx shopify app dev",
    "dev:local": "npx prisma generate && npx prisma db push && NODE_OPTIONS='--import ./instrumentation.server.mjs' npm exec react-router dev",
    "config:link": "shopify app config link",
    "generate": "shopify app generate",
    "deploy": "shopify app deploy",
    "start": "prisma migrate deploy && node scripts/run-startup-backfills.mjs && NODE_OPTIONS='--import ./instrumentation.server.mjs' react-router-serve ./build/server/index.js",
    "setup": "prisma generate && prisma migrate deploy",
    "shopify": "shopify",
    "prisma": "prisma",
    "validate:key": "node scripts/validate-encryption-key.js",
    "test:fynd-api": "node scripts/test-fynd-apis.mjs",
    "test:fynd-api:bash": "./scripts/test-fynd-apis.sh",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:components": "vitest run --config vitest.components.config.mts",
    "test:all": "vitest run && vitest run --config vitest.components.config.mts",
    "test:coverage": "vitest run --config vitest.coverage.config.mts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint app",
    "lint:fix": "eslint app --fix",
    "format": "prettier --write \"app/**/*.{ts,tsx,js,jsx,json,md,css,html}\"",
    "format:check": "prettier --check \"app/**/*.{ts,tsx,js,jsx,json,md,css,html}\"",
    "railway:login": "railway login",
    "railway:deploy": "railway up --detach",
    "railway:logs": "railway logs",
    "railway:status": "railway status",
    "railway:link": "railway link"
  },
  "type": "module",
  "engines": {
    "node": ">=22.12"
  },
  "dependencies": {
    "@gofynd/fdk-client-javascript": "^3.18.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-metrics-otlp-proto": "^0.213.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.213.0",
    "@opentelemetry/instrumentation-dns": "^0.56.0",
    "@opentelemetry/instrumentation-express": "^0.61.0",
    "@opentelemetry/instrumentation-fetch": "^0.213.0",
    "@opentelemetry/instrumentation-http": "^0.213.0",
    "@opentelemetry/instrumentation-net": "^0.57.0",
    "@opentelemetry/resources": "^2.6.0",
    "@opentelemetry/sdk-metrics": "^2.6.0",
    "@opentelemetry/sdk-node": "^0.213.0",
    "@opentelemetry/sdk-trace-node": "^2.6.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@prisma/client": "^6.19.2",
    "@prisma/instrumentation": "^7.5.0",
    "@react-router/dev": "^7.13.0",
    "@react-router/fs-routes": "^7.13.0",
    "@react-router/node": "^7.13.0",
    "@react-router/serve": "^7.13.0",
    "@shopify/app-bridge-react": "^4.2.10",
    "@shopify/shopify-app-react-router": "^1.1.1",
    "@shopify/shopify-app-session-storage-prisma": "^8.0.1",
    "bcryptjs": "^3.0.3",
    "ioredis": "^5.10.1",
    "isbot": "^5.1.32",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^8.0.1",
    "pino": "^10.3.1",
    "prisma": "^6.19.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "^7.13.0",
    "recharts": "^3.7.0",
    "vite-tsconfig-paths": "^6.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@faker-js/faker": "^10.4.0",
    "@shopify/polaris-types": "^1.0.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^22.19.0",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "ioredis-mock": "^8.13.1",
    "jsdom": "^29.1.1",
    "msw": "^2.14.3",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
