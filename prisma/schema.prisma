// Fynd Returns — Enterprise Returns Management for Shopify
// PostgreSQL for enterprise-grade multi-tenant data

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id                 String    @id
  shop               String
  state              String
  isOnline           Boolean   @default(false)
  scope              String?
  expires            DateTime?
  accessToken        String
  userId             BigInt?
  firstName          String?
  lastName           String?
  email              String?
  accountOwner       Boolean   @default(false)
  locale             String?
  collaborator       Boolean?  @default(false)
  emailVerified      Boolean?  @default(false)
  refreshToken       String?
  refreshTokenExpires DateTime?
}

model Shop {
  id          String   @id @default(cuid())
  shopDomain  String   @unique
  installedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  settings              ShopSettings?
  returnCases           ReturnCase[]
  apiKeys               ApiKey[]
  webhookSubscriptions  WebhookSubscription[]
}

model ShopSettings {
  id                         String   @id @default(cuid())
  shopId                     String   @unique
  shop                       Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  fyndApiType                String?  // "platform" | "storefront"
  fyndEnvironment            String?  // "uat" | "prod"
  fyndCustomBaseUrl          String?  // optional override
  appMode                    String?  // "dev" | "prod"
  fyndCompanyId              String?
  fyndApplicationId          String?
  fyndCredentials            String?
  policyJson                 String?
  statusMappingJson          String?
  notificationToggles          String?
  portalThemeJson            String?
  portalConfigJson           String?
  brandLogoUrl               String?  @db.Text // Base64 data URI or HTTPS URL for portal header logo
  brandFaviconUrl            String?  @db.Text // Base64 data URI or HTTPS URL for portal favicon
  returnWindowDays           Int      @default(30)
  returnReasonsJson          String?
  returnReasonsByCategoryJson String?
  returnPolicyText           String?
  autoApproveEnabled         Boolean  @default(false)
  autoRefundEnabled          Boolean  @default(false)  // Auto-trigger Shopify refund on credit_note_generated
  refundLocationMode         String   @default("auto") // "auto" = use order fulfillment location, "manual" = admin picks location in modal
  refundLocationId           String?  // Shopify location GID for auto mode fallback (when fulfillment location unavailable)
  refundPaymentMethod        String   @default("original") // "original" | "store_credit" | "both"
  refundStoreCreditPct       Int?     @default(100) // % of refund as store credit when method is "both"
  returnOffersJson          String?
  minimumReturnPrice         Decimal? @db.Decimal(12, 2)
  restrictedRegionsJson      String?
  noReturnPeriodEnabled      Boolean  @default(false)
  noReturnPeriodStart        DateTime?
  noReturnPeriodEnd          DateTime?
  restrictedProductTagsJson  String?
  photoRequired              Boolean  @default(false)
  returnFeeAmount            Decimal? @db.Decimal(12, 2)
  returnFeeCurrency          String?
  refundMethodPrepaidJson    String?
  refundMethodCODJson        String?
  notificationNewReturn      Boolean  @default(true)
  notificationApproved       Boolean  @default(true)
  notificationRejected       Boolean  @default(true)
  notificationRefunded       Boolean  @default(true)
  notificationCancelled      Boolean  @default(true)
  smtpHost                   String?
  smtpPort                   Int?     @default(587)
  smtpUser                   String?
  smtpPass                   String?
  smtpFromEmail              String?
  smtpFromName               String?
  smtpSecure                 Boolean  @default(false)
  adminNotifyEmail           String?
  adminSoundEnabled          Boolean  @default(true)
  readAllOrdersEnabled       Boolean  @default(false)

  // Store credit bonus incentive
  bonusCreditEnabled         Boolean  @default(false)
  bonusCreditPct             Int      @default(10) // Extra % bonus when customer chooses store credit/exchange

  // Green returns (keep item + refund)
  greenReturnsEnabled        Boolean  @default(false)
  greenReturnsThreshold      Decimal? @db.Decimal(12, 2) // Items below this value: customer keeps item
  greenReturnsProductTags    String?  // JSON array of product tags eligible for green returns

  // Advanced auto-approve rules
  autoApproveRulesJson       String?  @db.Text // JSON array of rule objects

  // Customer blocklist
  blocklistEnabled           Boolean  @default(false)

  // Multi-language portal
  portalLanguage             String   @default("en")
  portalLabelsJson           String?  @db.Text // JSON { key: translatedLabel } overrides

  // Shop locale, currency, timezone (auto-detected from Shopify)
  shopLocale                 String?  @default("en")
  shopCurrency               String?  @default("USD")
  shopTimezone               String?  @default("UTC")

  // Return shipping label
  defaultReturnInstructions  String?  @db.Text // Default instructions shown to customer after approval

  // Customizable email templates
  emailTemplatesJson         String?  @db.Text // JSON { eventType: { subject, bodyHtml } }

  // Product-level return policies
  productPoliciesJson        String?  @db.Text // JSON array: [{ match: {tags?, collections?, productTypes?}, windowDays, policyText? }]

  // Per sales-channel return policies (POS, B2B, Draft Orders)
  channelPoliciesJson        String?  @db.Text // JSON: { "pos": { returnEnabled, returnWindowDays, autoApproveEnabled }, "draft_order": {...}, "b2b": {...} }

  // Discount code refund
  discountCodeRefundEnabled  Boolean  @default(false)
  discountCodePrefix         String?  @default("RETURN")
  discountCodeExpiryDays     Int      @default(90)

  // Return offers / incentives
  returnOffersEnabled        Boolean  @default(false) // Offer discounts to keep item instead of returning

  // Portal exchange
  portalExchangeEnabled      Boolean  @default(false) // Allow customers to request exchange on portal

  // Configurable allowed fulfillment statuses for return eligibility
  portalAllowedFulfillmentStatuses String? // JSON array e.g. ["FULFILLED","PARTIALLY_FULFILLED","UNFULFILLED"]

  // Allowed Fynd statuses for refund eligibility — only when Fynd status is one of these can a refund be created
  // JSON array e.g. ["delivery_done","handed_over_to_customer"]. Empty/null = feature disabled (all refunds allowed).
  allowedFyndStatusesForRefund String? @db.Text

  // Refund gate preset: "none" | "after_pickup" | "after_delivery" | "after_qc" | "custom"
  // Presets auto-populate allowedFyndStatusesForRefund on save. null = "none".
  refundGatePreset             String?

  // Allowed Fynd statuses for return initiation — only when Fynd shipment status is one of these can a return be created from the portal
  // JSON array e.g. ["delivery_done","handed_over_to_customer"]. Empty/null = feature disabled (all forward statuses allowed).
  allowedFyndStatusesForReturn String? @db.Text

  // Return ID pattern configuration
  returnIdConfigJson       String?  @db.Text  // JSON: { prefix, separator, bodyMode, hashLength, sequentialPadding, suffix }
  returnIdCounter          Int      @default(0)  // Atomic sequential counter per shop

  // Fynd return consolidation
  fyndConsolidateReturns     Boolean  @default(false) // Batch multiple return cases into one Fynd return
  fyndConsolidateWindowHours Int      @default(4)     // Hours to wait before sending batch (1, 4, 8, 24)

  // Sync refund status back to Fynd (push credit_note_generated after Shopify refund)
  syncRefundToFynd           Boolean  @default(false)

  // WhatsApp / SMS notifications
  whatsappEnabled        Boolean  @default(false)
  whatsappProvider       String?  // "meta_cloud" | "twilio" | "wati" | "interakt"
  whatsappApiKey         String?
  whatsappPhoneNumberId  String?  // Meta Cloud: phone number ID
  whatsappFromNumber     String?  // E.164 format e.g. "+911234567890"

  // Portal OTP verification settings
  portalOtpEmailEnabled  Boolean  @default(false) // Require OTP for email-based lookups
  portalOtpSmsEnabled    Boolean  @default(false) // Require OTP for phone-based lookups

  // Scheduled report emails
  scheduledReportEnabled   Boolean  @default(false)
  scheduledReportFrequency String   @default("weekly")  // "daily" | "weekly" | "monthly"
  scheduledReportDay       Int      @default(1)          // day of week (1=Mon) or month (1-28)
  scheduledReportEmails    String   @default("")         // comma-separated recipients

  // Gift returns
  giftReturnsEnabled       Boolean  @default(false)

  // Gorgias helpdesk integration
  gorgiasEnabled           Boolean  @default(false)
  gorgiasApiKey            String?

  // Green returns - donate option
  greenReturnsDonateEnabled Boolean @default(false)
  greenReturnsDonateMessage String?  @db.Text

  // Per-reason restocking fees
  returnFeesByReasonJson   String?  @db.Text  // JSON: [{ reason, feeAmount, feeCurrency }]

  // Country-specific return windows
  returnWindowByCountryJson String? @db.Text  // JSON: [{ country, days }]

  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  blocklist                  BlocklistEntry[]
}

model ReturnCase {
  id                String   @id @default(cuid())
  returnRequestNo   String?  // User-friendly ID e.g. RPM-A1B2C3D4 for display and lookup
  shopId            String
  shop              Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  shopifyOrderId    String
  shopifyOrderName  String
  shopifyReturnId   String?
  fyndReturnId      String?
  fyndReturnNo      String?
  fyndOrderId       String?   // Fynd affiliate_order_id for API (from order customAttributes); NOT Shopify order name
  fyndShipmentId    String?   // main shipment ID from Fynd
  fyndPayloadJson   String?   // full Fynd order/shipment payload for invoice, AWB, DP, etc.
  fyndCurrentStatus String?   // Latest Fynd shipment status from webhook (e.g. "return_bag_in_transit")
  forwardAwb        String?
  returnAwb         String?
  customerEmailNorm String?
  customerPhoneNorm String?
  customerName      String?
  customerCity      String?
  customerCountry   String?
  customerAddress1  String?   // Street address line 1 (for return pickup)
  customerAddress2  String?   // Street address line 2 / apartment
  customerProvince  String?   // State / Province code
  customerZip       String?   // Postal code / ZIP / Pincode
  customerLandmark  String?   // Landmark (important for India logistics)
  status            String
  refundStatus      String?
  refundJson        String?   @db.Text  // JSON: { refundId, amount, currency, createdAt, method }
  adminNotes        String?
  notesForCustomer  String?   // published notes visible to customer in portal
  customerNotes     String?
  customerMediaJson String?   @db.Text  // JSON array of { name, mimeType, dataUrl } uploaded by customer
  rejectionReason   String?
  resolutionType    String    @default("refund") // "refund" | "exchange" | "store_credit" | "replacement"
  exchangeOrderId   String?   // Shopify order ID created for exchange
  exchangeOrderName String?   // Shopify order name for exchange
  exchangeItemsJson String?   @db.Text // JSON array of exchanged item details
  returnLabelUrl    String?   // URL to return shipping label (uploaded or generated)
  returnLabelJson   String?   @db.Text // JSON: { carrier, trackingNumber, labelUrl, qrCodeUrl }
  isGreenReturn     Boolean   @default(false) // Customer keeps item
  greenReturnAction String?   // "keep" | "donate" — what customer chose for green return
  isGiftReturn      Boolean   @default(false)
  giftRecipientName  String?
  giftRecipientEmail String?
  giftMessageToSender String?  @db.Text
  fraudRiskScore    Int?      // 0-100 computed at creation
  fraudRiskLevel    String?   // "low" | "medium" | "high" | "critical"
  bonusCreditAmount String?   // Extra bonus credit applied
  discountCode      String?   // Generated discount code for refund
  discountCodeValue String?   // Amount of the discount code
  currency          String?   // ISO 4217 currency code of the order (e.g. "INR", "USD")
  orderProcessedAt  DateTime? // Original order processed date (for deadline calculation)
  exchangePreference String?  @db.Text // Customer's free-text exchange request from portal
  exchangeVariantId  String?   // Shopify variant ID selected for exchange
  exchangePriceDiff  Decimal?  @db.Decimal(12, 2) // positive = customer owes, negative = store owes
  createdByChannel  String?   // "portal" | "admin" | "api" — how the return was created
  sourceChannel     String?   // "web" | "pos" | "draft_order" | "b2b" — Shopify order channel (source_name)
  createdByStaff    String?   // Staff email or name (for admin-created returns)
  crmTicketId       String?   // CRM/helpdesk ticket ID
  crmNotes          String?   @db.Text // CRM agent notes
  fyndSyncStatus    String?   // "pending" | "synced" | "failed" | "retry_scheduled" | "processing" | "pending_consolidation"
  fyndSyncRetries   Int      @default(0)
  fyndSyncError     String?  @db.Text
  fyndSyncNextRetry DateTime?
  lastFyndStatusCheck DateTime?
  // Cancellation request fields (customer-initiated return cancellation)
  cancellationRequestedAt  DateTime?  // When customer requested cancellation (null = no request)
  cancellationRequestedBy  String?    // "portal" | "admin" | "api"
  cancellationReason       String?    // Optional reason from customer
  cancellationDeclinedAt   DateTime?  // When admin declined cancellation (null = not declined)
  cancellationDeclinedBy   String?    // Admin email who declined
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  items  ReturnItem[]
  events ReturnEvent[]

  @@index([shopId, shopifyOrderName])
  @@index([shopId, forwardAwb])
  @@index([shopId, returnAwb])
  @@index([shopId, fyndReturnId])
  @@index([shopId, fyndShipmentId])
  @@index([shopId, fyndOrderId])
  @@index([shopId, returnRequestNo])
  @@index([shopId, customerEmailNorm])
  @@index([shopId, customerPhoneNorm])
  @@index([fyndSyncStatus, fyndSyncNextRetry])
  @@index([shopId, status])
  @@index([shopId, createdAt])
  @@index([shopId, resolutionType])
  @@index([shopId, status, createdAt])
  @@index([shopId, sourceChannel])
  // Per-shop uniqueness on the customer-visible return number. Two concurrent
  // creates can otherwise mint the same returnRequestNo (P1 finding from QA audit).
  // Note: returnRequestNo is nullable; null values are not constrained by @@unique
  // in PostgreSQL by default, which is the desired behaviour during creation.
  @@unique([shopId, returnRequestNo])
}

model ReturnItem {
  id               String    @id @default(cuid())
  returnCaseId     String
  returnCase       ReturnCase @relation(fields: [returnCaseId], references: [id], onDelete: Cascade)
  shopifyLineItemId String
  title            String?
  variantTitle     String?
  sku              String?
  price            String?
  imageUrl         String?
  qty              Int       @default(1)
  reasonCode       String?
  notes            String?
  condition        String?   // "unused" | "used_good" | "used_damaged" | "defective"
  fyndShipmentId       String?
  fyndBagId            String?
  fyndArticleId        String?
  fyndAffiliateLineId  String?
  fyndSellerIdentifier String?
  fyndItemId           String?
  fyndQuantityAvailable Int?
  fyndPriceEffective   String?
  fyndSize             String?
  fyndLineNumber       Int?
  createdAt        DateTime  @default(now())

  @@index([returnCaseId])
  @@index([returnCaseId, reasonCode])
}

model ReturnEvent {
  id          String   @id @default(cuid())
  returnCaseId String
  returnCase  ReturnCase @relation(fields: [returnCaseId], references: [id], onDelete: Cascade)
  source      String
  eventType   String
  payloadJson String?
  happenedAt  DateTime @default(now())

  @@index([returnCaseId])
}

model FyndWebhookLog {
  id               String   @id @default(cuid())
  shipmentId       String?
  orderId          String?
  affiliateOrderId String?
  refundStatus     String?
  fyndStatus       String?
  eventType        String?
  action           String?  // ignored | refund_in_progress | refund_completed | status_updated | status_noted | error | duplicate_ignored
  returnCaseId     String?
  carrier          String?
  awbNumber        String?
  trackingUrl      String?  @db.Text
  customerName     String?
  customerEmail    String?
  customerPhone    String?
  shopDomain       String?
  rawPayload       String?  @db.Text
  error            String?  @db.Text
  retryCount       Int      @default(0)
  retryAfter       DateTime?
  createdAt        DateTime @default(now())

  @@index([shipmentId])
  @@index([orderId])
  @@index([affiliateOrderId])
  @@index([returnCaseId])
  @@index([createdAt])
  @@index([action, retryAfter])
}

model FyndOrderMapping {
  id                String   @id @default(cuid())
  shopId            String
  shopifyOrderName  String
  shopifyOrderId    String?
  fyndOrderId       String?
  fyndShipmentId    String?
  searchStrategy    String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([shopId, shopifyOrderName])
  @@index([shopId, fyndOrderId])
  @@index([shopId, fyndShipmentId])
}

model LookupSession {
  id               String   @id @default(cuid())
  shopId           String
  lookupType       String
  lookupValueHash  String
  lookupValueNorm  String?
  matchedReturnIds String?
  otpTarget        String?
  otpSentAt        DateTime?
  verifiedAt       DateTime?
  expiresAt        DateTime
  attemptsCount    Int      @default(0)
  portalToken      String?
  createdAt        DateTime @default(now())

  @@index([shopId, lookupValueHash])
  // For the periodic cleanup query (`WHERE expiresAt < NOW()`). Without it, a busy
  // store with many OTP sessions causes a full table scan every cleanup pass.
  @@index([expiresAt])
  // For the account-level rate-limit query that aggregates failed attempts across
  // all sessions for a given lookup value within the last hour.
  @@index([shopId, lookupValueHash, createdAt])
}

model BlocklistEntry {
  id             String   @id @default(cuid())
  settingsId     String
  settings       ShopSettings @relation(fields: [settingsId], references: [id], onDelete: Cascade)
  type           String   // "email" | "phone" | "order_name" | "ip"
  value          String   // normalized value
  reason         String?
  blockedBy      String?  // admin who added
  createdAt      DateTime @default(now())

  @@unique([settingsId, type, value])
  @@index([settingsId, type])
}

model NotificationLog {
  id           String   @id @default(cuid())
  shopId       String
  returnCaseId String?
  channel      String   // "email" | "whatsapp" | "sms"
  recipient    String
  eventType    String   // "new_return" | "approved" | "rejected" | "refunded" | "otp" | "custom_note"
  subject      String?
  status       String   @default("sent") // "sent" | "failed"
  error        String?  @db.Text
  createdAt    DateTime @default(now())

  @@index([shopId, createdAt])
  @@index([returnCaseId])
}

model ApiKey {
  id          String    @id @default(cuid())
  shopId      String
  shop        Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  name        String
  keyHash     String    // bcrypt hash of the full API key
  keyPrefix   String    // first 8 chars for identification (e.g. "rpm_a1b2")
  permissions String    // JSON array: ["read_returns","write_returns","read_settings","manage_webhooks"]
  isActive    Boolean   @default(true)
  lastUsedAt  DateTime?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([shopId])
  @@index([keyPrefix])
}

model WebhookSubscription {
  id         String   @id @default(cuid())
  shopId     String
  shop       Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  url        String
  events     String   // JSON array: ["return.created","return.approved","return.rejected","return.refunded","return.status_changed"]
  secret     String   // HMAC secret for signature verification
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  failures   WebhookDeliveryFailure[]

  @@index([shopId])
}

/**
 * Dead-letter table for outbound webhooks that exhausted all retries. Lets the
 * merchant see *which* events failed (and why) and replay them, instead of
 * silently dropping the delivery in logs (P1 finding from QA audit).
 */
model WebhookDeliveryFailure {
  id              String              @id @default(cuid())
  subscriptionId  String
  subscription    WebhookSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  shopId          String
  eventType       String
  payloadJson     String              @db.Text
  url             String
  attemptCount    Int
  lastError       String?             @db.Text
  /** Idempotency key from the original payload (so a replay matches the same event). */
  idempotencyKey  String?
  createdAt       DateTime            @default(now())
  /** Filled in when an admin/cron manually replays — null while still failed. */
  replayedAt      DateTime?

  @@index([shopId, createdAt])
  @@index([subscriptionId])
  @@index([replayedAt])
}
