# Database - PostgreSQL (Railway provides this automatically via ${{Postgres.DATABASE_URL}})
# Local:  DATABASE_URL="postgresql://user:pass@host:5432/returnpromax?sslmode=require"
DATABASE_URL="postgresql://user:password@host:5432/returnpromax"

# Shopify (set by Shopify CLI when running `shopify app dev`)
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SCOPES=
SHOPIFY_APP_URL=

# Portal & Security (Required in production)
# Generate: openssl rand -hex 32
PORTAL_JWT_SECRET=
# Generate: openssl rand -hex 32
CRON_SECRET=
# Generate: openssl rand -hex 32 (64 hex chars) - encrypts Fynd credentials per shop
ENCRYPTION_KEY=
# Comma-separated retired keys (legacy ciphertext decrypts via these). Same format as ENCRYPTION_KEY.
# ENCRYPTION_KEYS_PREVIOUS=
# Default true: require shop-bound CSRF token on portal mutations. Set to "false" only as
# an emergency escape hatch if a portal deploy is mid-flight.
# PORTAL_CSRF_REQUIRED=true
# Fynd webhook signing secret (required in production for the global receiver;
# per-shop secrets in DB remain preferred for shop-specific callback URLs).
# Generate: openssl rand -hex 32
FYND_WEBHOOK_SECRET=
# Billing mode (required in production): "production" or "prod".
APP_BILLING_MODE=production
# Comma-separated emails of users allowed to access billing-override admin tools.
# SUPERADMIN_EMAILS=
# Shopify Managed Pricing app handle (required in production for billing redirect).
APP_MANAGED_PRICING_HANDLE=
# Pino log level (trace, debug, info, warn, error, fatal).
# LOG_LEVEL=info
# Build identifiers surfaced in observability logs.
# BUILD_VERSION=
# BUILD_COMMIT=
# Custom shop domain override (when not deploying behind *.myshopify.com).
# SHOP_CUSTOM_DOMAIN=

# Optional Redis URL for rate limiting. If unset, production uses Postgres
# rate-limit buckets through DATABASE_URL.
# REDIS_URL=redis://default:password@host:6379
# Treat startup backfill failures as fatal (default false — log and continue).
# Set to true on one-off deploys where you want to gate startup on a backfill.
# BACKFILL_STRICT=false

# Optional: Fynd API test (scripts/test-fynd-apis.mjs)
# FYND_CLIENT_ID=
# FYND_CLIENT_SECRET=
# FYND_COMPANY_ID=2263
# FYND_ORDER_ID=FYMP698CC01401C9F4A1
# FYND_TEST_UPDATE=1  # Set to run update-shipment-status (creates return)

# Email notifications are configured via SMTP in the app's Settings → Notifications page.
# No environment variables needed — SMTP credentials are stored in the database.
