# Database - PostgreSQL (required for Render; use Neon/Supabase free tier for local dev)
# Local:  DATABASE_URL="postgresql://user:pass@host:5432/returnpromax?sslmode=require"
# Render: Use Internal Database URL from Render dashboard
DATABASE_URL="postgresql://user:password@host:5432/returnpromax"

# Shopify (set by Shopify CLI when running `shopify app dev`)
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SCOPES=
SHOPIFY_APP_URL=

# Fynd Platform (configure in app Settings)
FYND_API_BASE_URL=https://api.fynd.com

# Portal & Security
PORTAL_JWT_SECRET=  # openssl rand -hex 32
ENCRYPTION_KEY=    # 32-byte hex for Fynd credentials
